# Ignore everything by default
*

# Git metadata (for workspace Cargo.toml git dependency)
!.git

# Root source and config files
!src/
!static/
!Cargo.lock
!Cargo.toml
!application.yaml
!banner.txt
!rustfmt.toml
!rust-toolchain.toml

# Crates directory (all subdirectories and Cargo.toml files needed for Docker build)
!crates/
!crates/**
