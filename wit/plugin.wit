// wit/plugin.wit
// version 0.0.1
package cosmox:plugin;

/// Shared type definition interface for the plugin system
interface cosmox-types {
  enum log-level {
    /// For extremely fine-grained event tracking. Corresponds to Rust `log::Level::Trace`.
    trace,

    /// Detailed event information for debugging purposes. Corresponds to Rust `log::Level::Debug`.
    /// Typically disabled in production environments.
    debug,

    /// General information on application progress and important events. Corresponds to Rust `log::Level::Info`.
    /// The default production environment log level.
    info,

    /// Conditions that may be problematic or undesirable but are recoverable. Corresponds to Rust `log::Level::Warn`.
    warn,

    /// Runtime errors or other unexpected conditions that affect a specific operation but the application can typically continue running.
    /// Corresponds to Rust `log::Level::Error`.
    error,

    /// Severe errors that cause the application to stop or become unavailable. Corresponds to Rust `log::Level::Error`.
    /// Note: Rust's `log` crate does not have a separate `Fatal` level, which is usually mapped to `Error` or handled customly.
    fatal,
  }

  /// Defines the configuration data used during plugin initialization and configuration
  /// The host and plugin need to agree on its content and serialization method, e.g., a JSON string
  record config-data {
    /// Unique identifier for the plugin
    id: string,

    /// Display name of the plugin
    name: string,

    /// Plugin configuration details, usually serialized data (e.g., a JSON string)
    settings: string,
  }

  /// Enum for the health status reported internally by the plugin
  enum plugin-status {
    /// The plugin is running normally
    ok,

    /// The plugin is running but with minor issues or warnings
    warning,

    /// The plugin has encountered a severe error and may not be working correctly
    error,

    /// The plugin has stopped running or is not active
    stopped,
  }

  /// Detailed health report of the plugin
  record plugin-health-status {
    /// Overall health status
    status: plugin-status,

    /// Optional health message or error details
    message: option<string>,

    /// Optional metric data, e.g., a JSON string or a specific format
    metrics: option<string>,
  }

  // --- Data type definitions shared between Host and Wasm ---

  /// Represents errors that can occur when registering an event listener.
  variant listener-registration-error {
    unknown,
    event-payload-decode-error(string),
    event-payload-encode-error(string),
    event-type-not-found, // The host does not support this event type
    listener-id-already-exists,
    invalid-listener-id,
    internal-registration-failure,
    permission-denied,
  }

  variant media-type-error {
    /// The requested type name is already registered by another plugin or the host.
    /// The associated string provides the conflicting type name.
    already-exists(string),

    /// The provided type name or info is malformed.
    /// The associated string explains the reason for the invalid format.
    invalid-format(string),

    /// The plugin lacks the necessary permissions to register the type.
    /// This is a security-related error.
    permission-denied,
  }

  /// Represents a generic key-value pair, used for passing event metadata or query results.
  record key-value-pair {
    key: string,
    value: string,
  }

  /// Generic event payload, the Wasm plugin is responsible for parsing.
  record event-payload {
    /// Unique event instance ID, used for tracking.
    event-instance-id: string,

    /// Event type (must match the one used during registration).
    event-type: string,

    /// Context ID when the event was triggered, can be used for query-host-context.
    context-id: option<string>,

    /// The main data of the event, can be any binary format (default is bincode).
    data: list<u8>,

    /// Additional metadata.
    metadata: list<key-value-pair>,
  }

  /// Event processing result, returned by the Wasm plugin to the host.
  record event-response {
    /// Processing status.
    status: processing-status, // Can reuse the previous processing-status

    /// If an error occurs, provides an error code.
    error-code: option<error-code>, // Can reuse the previous error-code

    /// The result data after plugin processing, which the host may need for subsequent processing or responses.
    processed-data: option<list<u8>>,

    /// Additional logs generated by the plugin.
    logs: list<string>,

    /// Metrics generated by the plugin.
    metrics: list<key-value-pair>,
  }

  // Defines possible error codes (if the previous processing-status and error-code are not included here)
  // Assumes they are independently defined in other shared WIT and referenced here.
  enum processing-status {
    ok,
    err
  }

  enum error-code {
    ok,
    err
  }

  /// The result type for a plugin operation, used to return success or failure information
  variant plugin-result {
    ok,
    err(string),
  }
}

/// Core plugin lifecycle interface
interface core-lifecycle {
  use cosmox-types.{config-data, plugin-result};

  /// Called when the plugin is first recognized by the host after being loaded.
  /// Used to perform one-time setup, such as loading configuration and initializing internal state.
  /// Returns a plugin-result, indicating whether the initialization was successful.
  on-load: func(config: config-data) -> plugin-result;

  /// Called when the plugin is enabled and ready to perform its main functions.
  /// Returns a plugin-result, indicating whether the activation was successful.
  on-enable: func() -> plugin-result;

  /// Called when the plugin is disabled but not yet unloaded from memory.
  /// Used to pause the plugin's main functions and release short-term resources.
  on-disable: func() -> plugin-result;

  /// Called when the plugin is about to be unloaded from memory and is no longer needed.
  /// Used to perform cleanup tasks, such as saving state and releasing all long-term resources.
  on-unload: func() -> plugin-result;
}

/// Plugin configuration management interface
interface configuration-manager {
  use cosmox-types.{config-data, plugin-result};

  /// Gets the plugin's current configuration.
  /// The host can get the plugin's internal configuration state through this interface.
  get-current-config: func() -> config-data;

  /// Applies a new configuration to the plugin.
  /// The host can dynamically update the plugin's configuration through this interface.
  apply-new-config: func(config: config-data) -> plugin-result;

  /// Gets the media types supported by the plugin
  supported-media-types: func() -> list<string>;
}

/// Host notification interface, used for the host to send general events or status updates to the plugin
interface host-notifier {
  use cosmox-types.{plugin-result};

  /// Called when the host environment changes, such as a host program version update or user session change.
  /// `event` is binary or serialized data related to the event.
  on-event: func(event: list<u8>) -> plugin-result;
}

/// Plugin telemetry and health report interface
interface telemetry-reporter {
  use cosmox-types.{plugin-health-status};

  /// Called when the host program periodically needs the plugin's health status or performance metrics.
  get-health-status: func() -> plugin-health-status;
}

/// External command handling interface, used for the host to send specific commands to the plugin
interface command-handler {
  use cosmox-types.{plugin-result};

  /// Called when the host program receives a specific command for this plugin or needs the plugin to perform a specific operation.
  /// `command-name` is the name of the command, such as "reset-cache", "export-data".
  /// `args` is the list of command parameters.
  execute-command: func(command-name: string, args: list<string>) -> plugin-result;
}

/// API interfaces from the host
interface cosmox-api {
  use cosmox-types.{listener-registration-error, log-level};

  /// Used to print logs or debug information to the host environment
  log: func(level: log-level,message: string);

  /// The host provides a callback mechanism for registering a plugin's listener for a specific event.
  /// Parameters:
  ///    event-type: The event type (e.g., "http-request-received", "file-accessed", "user-login").
  ///    listener-id: A unique ID used internally by the Wasm plugin to identify this listener.
  /// Returns: Whether the registration was successful, and any errors that occurred.
  register-event-listener: func(event: list<u8>) -> result<_, listener-registration-error>;

  /// The host provides a callback mechanism for unregistering an event listener.
  unregister-event-listener: func(event: list<u8>) -> result<_, listener-registration-error>;

  /// The host provides an interface that allows the plugin to query host status or perform operations based on the event context.
  /// For example, a listener for an HTTP request event might need to access request headers.
  /// This can be a generic query interface, or more specific like get-request-header
  query-host-context: func(query-key: string, context-id: string) -> option<list<u8>>;
  // Or:
  // get-http-request-header: func(request-context-id: string, header-name: string) -> option<string>;

  /// Get supported media types in cosmox
  /// This API returns the media types supported by `cosmox` and those extended by `plugins`.
  get-supported-media-types: func() -> list<string>;
}

/// The plugin's "world," defining all the interfaces imported and exported by the plugin
world plugin-host-world {
  // import wasi:cli/stdout@0.2.0;
  // import wasi:cli/environment@0.2.0;
  // import wasi:cli/exit@0.2.0;
  // import wasi:cli/stderr@0.2.0;

  import cosmox-api;

  export core-lifecycle;
  export configuration-manager;
  export host-notifier;
  export telemetry-reporter;
  export command-handler;

  export run: func();
}
